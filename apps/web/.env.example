NEXT_PUBLIC_API_URL=http://localhost:4001
# After replacing companion .vrm files (same filename), bump this so the app requests a new URL and skips stale browser / Three.js cache. Restart `next dev` after changing.
# NEXT_PUBLIC_VRM_CACHE_BUST=2
# Companion VRM: default yaw is π (face the camera). Set to 0 if your model already faces you and looks wrong.
# NEXT_PUBLIC_VRM_YAW=0
# Companion arms: raw-bone relax after load; spring joints are removed unless you set:
# NEXT_PUBLIC_VRM_KEEP_SPRING_BONES=1
# Re-enable three-vrm normalized→raw bone sync each frame (default off — it resets arms to T-pose).
# NEXT_PUBLIC_VRM_AUTO_UPDATE_HUMAN_BONES=1
# Upper-arm drop: x (default), z, or xz — z-only with large angles can pin arms behind the back on some rigs.
# NEXT_PUBLIC_VRM_ARM_DROP_AXIS=x
# NEXT_PUBLIC_VRM_RELAX_ARM_PITCH_DEG=58
# NEXT_PUBLIC_VRM_RELAX_ARM_PITCH_SIGN=-1
# NEXT_PUBLIC_VRM_RELAX_ARM_ROLL_DEG=8
# NEXT_PUBLIC_VRM_RELAX_ARM_Z_SIGN=1
# Sleep & Activity page + mouse tracker: FastAPI in apps/ml-service (default http://localhost:5000).
NEXT_PUBLIC_ML_URL=http://localhost:5000
# Handwriting page (/handwriting) — Flask in apps/handwriting-api (port 5002).
NEXT_PUBLIC_HANDWRITING_API_URL=http://localhost:5002
# Proxies /graphrag-static/* → {this}/static/* so the Next Companion page can load GLTFs from graphrag/static (same URL as Nest RAG_SERVICE_URL).
RAG_SERVICE_URL=http://127.0.0.1:8090
