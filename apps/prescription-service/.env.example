# Fast defaults (2 OCR passes, smaller images, cached drug DB)
PRESCRIPTION_OCR_MAX_VARIANTS=2
PRESCRIPTION_MAX_IMAGE_SIDE=1600
PRESCRIPTION_OCR_EARLY_EXIT_SCORE=14
PRESCRIPTION_OLLAMA_NUM_PREDICT=320
PRESCRIPTION_OLLAMA_NUM_CTX=2048
PRESCRIPTION_USE_OLLAMA=1
PRESCRIPTION_DRUG_DB_ONLINE=1
PRESCRIPTION_FUZZY_MAX_WORDS=35

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# Set to 0 to skip RxNorm/BDPM download (uses built-in + cache only)
# PRESCRIPTION_DRUG_DB_ONLINE=0
