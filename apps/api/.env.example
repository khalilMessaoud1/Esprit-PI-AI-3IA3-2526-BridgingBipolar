PORT=4001
JWT_SECRET=replace_this_secret
JWT_EXPIRES_IN=7d
DATABASE_URL=postgresql://bridging:bridging@localhost:5432/bridgingbipolar
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace
AWS_SECRET_ACCESS_KEY=replace
AWS_S3_BUCKET=bridgingbipolar-uploads
# Python FastAPI service (apps/prescription-service) — OCR + extraction
PRESCRIPTION_SERVICE_URL=http://127.0.0.1:5020

# GraphRAG adapter (repo /rag_api) — companion chat
RAG_SERVICE_URL=http://127.0.0.1:8090
# RAG_API_KEY=optional_shared_secret
# Companion **photo** flow: the RAG/graphrag service calls Ollama (default http://localhost:11434 on that machine).
# Photo captions use Ollama vision on the **graphrag** host (`inetgration/youssef/.env`): default model is `moondream`
# (run `ollama pull moondream`). CPU + `llava:7b` is slow — prefer moondream or a GPU for heavier vision models.
# Nest waits up to this many ms for RAG /chat/image (vision + reply). Default 900000 (15 min).
# RAG_CHAT_IMAGE_TIMEOUT_MS=900000

PARENT_WHATSAPP_DEFAULT_COUNTRY_CODE=216

# -- Account SID + Auth Token: Twilio Console → Account → API keys & tokens.
# Sandbox “from”: whatsapp:+14155238886 (join sandbox from Twilio WhatsApp sandbox page).
# For template sends: Messaging → Content → copy Content SID (HX…). Parent “to” must use whatsapp:+E164.
TWILIO_ACCOUNT_SID='AC4ba9838a3ec7ed3d0677a2e5a1b1e20b'
TWILIO_AUTH_TOKEN='8570e1e2444917952edd2c6a8d57acba'
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content API (recommended). If set, message uses content_sid + content_variables (no free-text body).
TWILIO_WHATSAPP_CONTENT_SID='HXb5b62575e6e4ff6129ad7c8efe1f983e'
# Optional JSON for template {{1}}, {{2}}, … If empty, app builds name + urgent suicidal-ideation line for {{2}}.
# TWILIO_WHATSAPP_CONTENT_VARIABLES={"1":"Alex","2":"they may be having suicidal thoughts — call them now."}
# Full free-text body override (only when TWILIO_WHATSAPP_CONTENT_SID is empty). Use {name} for the user’s display name.
# TWILIO_CRISIS_MESSAGE_BODY=Urgent! Check on {name} — they may be having suicidal thoughts. Please reach them now.
# Aliases if you prefer other names: TWILIO_CRISIS_CONTENT_SID, TWILIO_CONTENT_SID, CRISIS_ALERT_TEMPLATE_SID
# TWILIO_CRISIS_CONTENT_VARIABLES_JSON=...

# --- Crisis strike counter (uses same REDIS_URL as session memory) ---
CRISIS_STRIKE_THRESHOLD=3
CRISIS_STRIKES_TTL_SECONDS=7776000
CRISIS_PARENT_COOLDOWN_SECONDS=2592000
CRISIS_REDIS_KEY_PREFIX=graphrag:crisis

# WhatsApp strike counting runs inside the RAG service — set REDIS_URL there (inetgration/youssef/.env).
# Nest Twilio vars above are used only when RAG does not send parent WhatsApp (fallback after 3 local text hits).