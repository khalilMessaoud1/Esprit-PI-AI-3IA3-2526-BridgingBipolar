# BridgingBipolar — environment templates (no secrets here)
#
# Copy each file below to `.env` in the same folder before first run:
#
#   apps/web/.env.example          → apps/web/.env
#   apps/api/.env.example          → apps/api/.env
#   apps/prescription-service/.env.example → apps/prescription-service/.env
#   inetgration/youssef/.env.example → inetgration/youssef/.env
#
# Or run:  .\scripts\setup-env.ps1
#
# Never commit real `.env` files or API keys to GitHub.
