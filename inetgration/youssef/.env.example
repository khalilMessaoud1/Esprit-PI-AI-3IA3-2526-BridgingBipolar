# Copy to .env and fill in real values (never commit .env)
# Used by GraphRAG / RAG companion (rag_api loads graphrag from inetgration/youssef)

WEB_PORT=8002
BIPOLAR_MONITOR_URL=http://127.0.0.1:8001

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=bipolar_chunks

RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_SKIP_RERANKER=1

# Optional — crisis strike counter (leave empty for local dev without Redis)
REDIS_URL=

OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=192
OLLAMA_KEEP_ALIVE=30m
OLLAMA_GENERATE_TIMEOUT_SEC=120
OLLAMA_VISION_TIMEOUT_SEC=900
VISION_IMAGE_MAX_SIDE=1024
VISION_JPEG_QUALITY=80
WHISPER_MODEL=base

RAG_TOP_K=6
RAG_RERANK_TOP_N=4
RAG_GRAPH_HOPS=0
RAG_HISTORY_TURNS=8
RAG_COMPACT_PROMPT=1
